{
    "$schema": "https://smapi.io/schemas/content-patcher.json",
    "Format": "2.9.1",
    "Changes": [

        //Lade NPC Kuro
        {
            "Action": "Load",
            "Target": "Characters/Kuro",
            "FromFile": "assets/Characters/Kuro.png"
        },
        {
            "Action": "Load",
            "Target": "Portraits/Kuro",
            "FromFile": "assets/Portraits/Kuro.png"
        },
        {
            "Action": "Load",
            "Target": "Characters/Dialogue/Kuro",
            "FromFile": "assets/Characters/Dialogue/KuroDialogue.json"
        },
        {
            "Action": "Load",
            "Target": "Characters/Schedules/Kuro",
            "FromFile": "assets/Characters/schedules/KuroSchedule.json"
        },

        //Lade KuroZelt
        {
            "Action": "Load",
            "Target": "Maps/KuroZelt",
            "FromFile": "assets/Maps/KuroZelt.tmx"
        },

        //Eine Map-Änderung (z.B. ein Stück der Stadt bearbeiten)
        {
            "Action": "EditMap",
            "Target": "Maps/BusStop",
            "FromFile": "assets/Maps/BusStop.tmx",
            "FromArea":{"X": 32, "Y": 12, "Width": 5, "Height": 8},
            "ToArea": {"X": 32, "Y": 12, "Width": 5, "Height": 8}
            },
        {
            "Action": "EditMap",
            "Target": "Maps/Town",
            "FromFile": "assets/Maps/Town.tmx",
            "FromArea":{"X": 109, "Y": 41, "Width": 21, "Height": 69},
            "ToArea": {"X": 109, "Y": 41, "Width": 21, "Height": 69}
            }, 

        //Eine Map Änderung (bereits vorhandene Objekte entfernen, z.B. Büsche an der Bushaltestelle)
        {
            "Action": "EditData",
            "Target": "Data/Locations",
            "Fields": {
                "BusStop": {
                    "FixedBushes": [
                        {
                            "Id": "32_17", // SMAPI nutzt oft die Koordinate als ID
                            "Action": "Remove"
                        }
                    ]
                }
            }
        },

        //Erstellt einen neuen Ort (Kuros Zelt)
        {
            "Action": "EditData",
            "Target": "Data/Locations",
            "Entries": {
                "KuroZelt": {               // <-- Dieser Name muss mit dem Namen im Warp übereinstimmen
                    "DisplayName": "Kuros Zelt",
                    "Map": "Maps/KuroZelt", // Verweis auf die geladene Map
                    "IsStructure": true,    // Sagt dem Spiel: "Das ist ein Gebäude-Innenraum" (wie das Haus von Caroline)
                    "ExcludeFromRandomEncounters": true,
                    "CreateNpcInLocation": false,
                    "CreateOnLoad": {
                        "MapPath": "Maps/KuroZelt",
                    }
                }
            }
        },
        
        //Erstellt NPC Kuro
        {
            "Action": "EditData",
            "Target": "Data/Characters",
            "Entries": {
                "Kuro": {
                    "DisplayName": "Kuro",
                    "BirthSeason": "Winter",
                    "BirthDay": 4,
                    "HomeRegion": "Other",
                    "Gender": "Male", // Male, Female, Undefined
                    "Age": "Adult",        // Child, Teen, Adult
                    "Manners": "Polite",   // Polite, Neutral, Rude
                    "SocialAnxiety": "Shy",   // Outgoing, Neutral, Shy
                    "Optimism": "Negative",   // Positive, Neutral, Negative
                    "CanBeRomanced": true,
                    "IntroductionsQuest": true,
                    "ItemDeliveryQuests": true,
                    "DumpsterDiveEmote": 4,
                    "DumpsterDiveFriendshipEffect": 0,
                    "Home": [{
                        "Id": "KuroZelt",
                        "Location": "KuroZelt", // Wo er wohnt
                        "Tile": { "X": 3, "Y": 6 }, // Die Koordinaten auf der Map an denen er Spawnt
                        "Direction": "right" // Die Richtung, in die er schaut
                        }
                    ]
                }
            }
        }
    ]
}
